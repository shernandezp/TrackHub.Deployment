# =============================================================================
# TrackHub Frontend-Only Environment Configuration
# =============================================================================
# For split deployment where frontend is on a separate server
# Copy this file to .env and update values before deployment
# =============================================================================

# Your frontend domain
DOMAIN=frontend.your-domain.com

# Backend server URL (where all APIs are hosted)
BACKEND_URL=https://api.your-domain.com

# =============================================================================
# REACT FRONTEND CONFIGURATION
# =============================================================================

# Default map center coordinates
REACT_APP_DEFAULT_LAT=4.624335
REACT_APP_DEFAULT_LNG=-74.063644

# OAuth Client ID
REACT_APP_CLIENT_ID=web_client

# OAuth Endpoints (pointing to backend server)
REACT_APP_AUTHORIZATION_ENDPOINT=https://api.your-domain.com/Identity/authorize
REACT_APP_TOKEN_ENDPOINT=https://api.your-domain.com/Identity/token
REACT_APP_CALLBACK_ENDPOINT=https://frontend.your-domain.com/authentication/callback
REACT_APP_REVOKE_TOKEN_ENDPOINT=https://api.your-domain.com/Identity/revoke
REACT_APP_LOGOUT_ENDPOINT=https://api.your-domain.com/Identity/logout

# API Endpoints (pointing to backend server)
REACT_APP_MANAGER_ENDPOINT=https://api.your-domain.com/Manager/graphql
REACT_APP_ROUTER_ENDPOINT=https://api.your-domain.com/Router/graphql
REACT_APP_SECURITY_ENDPOINT=https://api.your-domain.com/Security/graphql
REACT_APP_GEOFENCING_ENDPOINT=https://api.your-domain.com/Geofence/graphql
REACT_APP_REPORTING_ENDPOINT=https://api.your-domain.com/Reporting/
