{
  "scopes": [
    {
      "name": "web_scope",
      "resource": "trackhub_api"
    },
    {
      "name": "mobile_scope",
      "resource": "trackhub_api"
    },
    {
      "name": "sec_scope",
      "resource": "trackhub_api"
    }
  ],
  "PKCEClients": [
    {
      "clientId": "web_client",
      "uri": "https://<<YOUR_DOMAIN>>/authentication/callback",
      "scope": "web_scope"
    }
  ],
  "serviceClients": [
    {
      "clientId": "syncworker_client",
      "clientSecret": "<<GENERATE_A_SECURE_SECRET>>"
    }
  ]
}
