# =============================================================================
# TrackHub Environment Configuration
# =============================================================================
# Copy this file to .env and update values before deployment
# DO NOT commit the .env file to version control
# =============================================================================

# =============================================================================
# GENERAL SETTINGS
# =============================================================================

# Your domain name (e.g., trackhub.example.com)
DOMAIN=your-domain.com

# Allowed CORS origins (frontend URL)
ALLOWED_CORS_ORIGINS=https://your-domain.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection strings
# Format: server=<host>;user id=<user>;password=<password>;database=<dbname>;port=<port>

# Security database connection
DB_CONNECTION_SECURITY="server=your-db-server.com;user id=postgres;password=YOUR_SECURE_PASSWORD;database=TrackHubSecurity;port=5432"

# Manager/Application database connection
DB_CONNECTION_MANAGER="server=your-db-server.com;user id=postgres;password=YOUR_SECURE_PASSWORD;database=TrackHub;port=5432"

# =============================================================================
# CERTIFICATE CONFIGURATION
# =============================================================================

# Password for the OpenIddict certificate (certificate.pfx)
CERTIFICATE_PASSWORD=your-certificate-password

# OpenIddict scopes
OPENIDDICT_SCOPES=mobile_scope,web_scope,sec_scope

# =============================================================================
# ENCRYPTION
# =============================================================================

# Encryption key for secrets stored in the database (use a GUID format)
ENCRYPTION_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# =============================================================================
# SERVICE URLs (Internal Docker Network)
# =============================================================================

# Authority server URL (how services reach the identity provider)
AUTHORITY_URL=https://your-domain.com/Identity

# GraphQL service endpoints (internal Docker network URLs)
GRAPHQL_IDENTITY_SERVICE=http://security:8080/graphql/
GRAPHQL_SECURITY_SERVICE=http://security:8080/graphql/
GRAPHQL_MANAGER_SERVICE=http://manager:8080/graphql/
GRAPHQL_ROUTER_SERVICE=http://router:8080/graphql/
GRAPHQL_GEOFENCE_SERVICE=http://geofencing:8080/graphql/

# =============================================================================
# REACT FRONTEND CONFIGURATION
# =============================================================================

# Default map center coordinates (when user denies location permission)
REACT_APP_DEFAULT_LAT=4.624335
REACT_APP_DEFAULT_LNG=-74.063644

# OAuth Client ID
REACT_APP_CLIENT_ID=web_client

# OAuth Endpoints (public URLs)
REACT_APP_AUTHORIZATION_ENDPOINT=https://your-domain.com/Identity/authorize
REACT_APP_TOKEN_ENDPOINT=https://your-domain.com/Identity/token
REACT_APP_CALLBACK_ENDPOINT=https://your-domain.com/authentication/callback
REACT_APP_REVOKE_TOKEN_ENDPOINT=https://your-domain.com/Identity/revoke
REACT_APP_LOGOUT_ENDPOINT=https://your-domain.com/Identity/logout

# API Endpoints (public URLs)
REACT_APP_MANAGER_ENDPOINT=https://your-domain.com/Manager/graphql
REACT_APP_ROUTER_ENDPOINT=https://your-domain.com/Router/graphql
REACT_APP_SECURITY_ENDPOINT=https://your-domain.com/Security/graphql
REACT_APP_GEOFENCING_ENDPOINT=https://your-domain.com/Geofence/graphql
REACT_APP_REPORTING_ENDPOINT=https://your-domain.com/Reporting/

# =============================================================================
# SYNCWORKER CONFIGURATION
# =============================================================================

# SyncWorker OAuth client credentials (register this client in AuthorityServer)
SYNCWORKER_CLIENT_ID=sync_worker_client
SYNCWORKER_CLIENT_SECRET=your-syncworker-client-secret
